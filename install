#!/bin/sh
set -eu

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*"
    exit 1
}

success() {
    printf '\n\033[32m✓\033[0m %s\n' "$*"
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

# Verify .env exists and SA_PASSWORD is set
if [ ! -f .env ]; then
    die ".env file not found. Copy .env.example to .env and fill in the required values."
fi

# shellcheck source=/dev/null
. ./.env

if [ -z "${SA_PASSWORD:-}" ]; then
    die "SA_PASSWORD is not set in .env. Please set it before running install."
fi

success ".env validated"

# Create host directories for SQL Server data volumes
info "Creating data directories..."
mkdir -p /data/mssql/data     || die "could not create /data/mssql/data"
mkdir -p /data/mssql/logs     || die "could not create /data/mssql/logs"
mkdir -p /data/mssql/security || die "could not create /data/mssql/security"

success "Data directories created"

# Set ownership for the mssql process (UID 10001, GID 0)
info "Setting directory permissions for SQL Server..."
chown 10001:0 /data/mssql/data     || die "could not set permissions on /data/mssql/data"
chown 10001:0 /data/mssql/logs     || die "could not set permissions on /data/mssql/logs"
chown 10001:0 /data/mssql/security || die "could not set permissions on /data/mssql/security"

success "Directory permissions set"

# Create external Docker volumes bound to host directories
info "Creating Docker volumes..."
docker volume create --opt type=none --opt device=/data/mssql/data     --opt o=bind mssql_data     || die "could not create Docker volume mssql_data"
docker volume create --opt type=none --opt device=/data/mssql/logs     --opt o=bind mssql_logs     || die "could not create Docker volume mssql_logs"
docker volume create --opt type=none --opt device=/data/mssql/security --opt o=bind mssql_security || die "could not create Docker volume mssql_security"

success "Docker volumes created"

# Open SQL Server port for private networks using firewall-cmd
MSSQL_PORT=1433

allow_ipv4() {
    subnet="$1"
    port="$2"
    protocol="$3"
    firewall-cmd --permanent \
        --add-rich-rule="rule family='ipv4' source address='${subnet}' port port='${port}' protocol='${protocol}' accept" \
        || die "could not add IPv4 firewall rule for ${subnet}:${port}/${protocol}"
}

allow_ipv6() {
    subnet="$1"
    port="$2"
    protocol="$3"
    firewall-cmd --permanent \
        --add-rich-rule="rule family='ipv6' source address='${subnet}' port port='${port}' protocol='${protocol}' accept" \
        || die "could not add IPv6 firewall rule for ${subnet}:${port}/${protocol}"
}

info "Opening port ${MSSQL_PORT}/tcp for private networks..."

allow_ipv4 "10.0.0.0/8"      "${MSSQL_PORT}" "tcp"
allow_ipv4 "172.16.0.0/12"   "${MSSQL_PORT}" "tcp"
allow_ipv4 "192.168.0.0/16"  "${MSSQL_PORT}" "tcp"

allow_ipv6 "fc00::/7"        "${MSSQL_PORT}" "tcp"
allow_ipv6 "fe80::/10"       "${MSSQL_PORT}" "tcp"

firewall-cmd --reload || die "could not reload firewall rules"

success "Firewall rules applied"

# Pull latest images and start services
docker compose pull  || die "could not pull latest images"
docker compose up -d || die "could not start services"

success "SQL Server installed and running"
