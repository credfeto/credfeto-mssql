#!/bin/sh
set -eu

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*"
    exit 1
}

success() {
    printf '\n\033[32m✓\033[0m %s\n' "$*"
}

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

printf '\n\033[32m→\033[0m Stopping and removing containers...\n'
docker compose down
docker compose rm -f

printf '\n\033[32m→\033[0m Pruning unused Docker resources...\n'
docker system prune -f

success "Clean-up complete"

"${SCRIPT_DIR}/update"
